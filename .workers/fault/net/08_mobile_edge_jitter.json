{
  "version": 1,
  "name": "Mobile edge jitter",
  "lo": {
    "default": {
      "delay": {
        "time_ms": 2
      }
    },
    "rules": [
      {
        "match": {
          "proto": "tcp",
          "dport": 9100,
          "bidirectional": true
        },
        "delay": {
          "time_ms": 110,
          "jitter_ms": 25,
          "correlation": 0.35,
          "distribution": "normal"
        }
      }
    ]
  }
}
